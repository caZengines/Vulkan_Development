{
    "cmake.configureOnOpen": true,
    "C_Cpp.default.includePath": [
        "${workspaceFolder}/**",
        "${env:VULKAN_SDK}/Include"
    ],
    "C_Cpp.intelliSenseEngine": "disabled",
    "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/cmake-build",
    "--background-index",
    "--query-driver=C:/msys64/ucrt64/bin/g++.exe"
]
}